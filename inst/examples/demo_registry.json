{
  "name": "bittner_creek_demo",
  "version": "0.1.0",
  "source": "bcrestoration_mobile.qgs",
  "layers": {
    "watershed": {
      "type": "polygon",
      "fill": {
        "color": "#a8c8e0",
        "opacity": 0.4
      },
      "stroke": {
        "color": "#2c3e50",
        "width": 1.8
      }
    },
    "lake": {
      "type": "polygon",
      "source_layer": "whse_basemapping.fwa_lakes_poly",
      "fill": {
        "color": "#dcecf4",
        "opacity": 0.7
      },
      "stroke": {
        "color": "#1f78b4",
        "width": 0.2
      }
    },
    "stream": {
      "type": "line",
      "stroke": {
        "color": "#7ba7cc",
        "width": 1.2
      }
    },
    "railway": {
      "type": "line",
      "source_layer": "whse_basemapping.gba_railway_tracks_sp",
      "stroke": {
        "color": "#000000",
        "width": 1.2
      }
    },
    "road": {
      "type": "line",
      "source_layer": "whse_basemapping.transport_line",
      "classification": {
        "field": "road_type",
        "classes": {
          "RH1": {
            "color": "#c0392b",
            "width": 2.0,
            "label": "Highway"
          },
          "RA1": {
            "color": "#e67e22",
            "width": 1.8,
            "label": "Primary Arterial"
          },
          "RA2": {
            "color": "#f1c40f",
            "width": 1.4,
            "label": "Secondary Arterial"
          },
          "RC2": {
            "color": "#f7dc6f",
            "width": 1.0,
            "label": "Collector"
          },
          "RLO": {
            "color": "#484848",
            "width": 0.46,
            "label": "Local"
          }
        }
      }
    },
    "crossing": {
      "type": "point",
      "source_layer": "whse_fish.pscis_assessment_svw",
      "classification": {
        "field": "barrier_result_code",
        "classes": {
          "BARRIER": {
            "color": "#ca3c3c",
            "radius": 3,
            "label": "Barrier"
          },
          "PASSABLE": {
            "color": "#33a02c",
            "radius": 3,
            "label": "Passable"
          },
          "POTENTIAL": {
            "color": "#ff7f00",
            "radius": 3,
            "label": "Potential Barrier"
          },
          "UNKNOWN": {
            "color": "#bf2ac4",
            "radius": 3,
            "label": "Unknown"
          }
        }
      }
    }
  }
}
