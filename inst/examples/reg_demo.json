{
  "name": "bittner_creek_demo",
  "version": "0.1.0",
  "source": "bcrestoration_mobile.qgs",
  "layers": {
    "conservancy": {
      "type": "polygon",
      "source_layer": "whse_tantalis.ta_conservancy_areas_svw",
      "fill": {
        "color": "#639b5f",
        "opacity": 0.161
      },
      "stroke": {
        "color": "#33a02c",
        "width": 0.66
      },
      "label": {
        "font": "Courier",
        "size": 8,
        "color": "#639b5f"
      }
    },
    "crossings_pscis_assessment": {
      "type": "point",
      "source_layer": "whse_fish.pscis_assessment_svw",
      "classification": {
        "field": "barrier_result_code",
        "classes": {
          "BARRIER": {
            "color": "#ca3c3c",
            "shape": "circle",
            "radius": 3
          },
          "PASSABLE": {
            "color": "#33a02c",
            "shape": "circle",
            "radius": 3
          },
          "POTENTIAL": {
            "color": "#ff7f00",
            "shape": "circle",
            "radius": 3
          },
          "UNKNOWN": {
            "color": "#bf2ac4",
            "shape": "circle",
            "radius": 3
          },
          "__empty__": {
            "color": "#c052df",
            "shape": "circle",
            "radius": 3
          }
        }
      },
      "label": {
        "font": ".AppleSystemUIFont",
        "size": 9,
        "color": "#323232",
        "halo": {
          "color": "#fafafa",
          "width": 0.75
        }
      }
    },
    "lake": {
      "type": "polygon",
      "source_layer": "whse_basemapping.fwa_lakes_poly",
      "fill": {
        "color": "#dcecf4",
        "opacity": 0.7
      },
      "stroke": {
        "color": "#1f78b4",
        "width": 0.2
      },
      "label": {
        "font": "Helvetica",
        "size": 10,
        "style": "italic",
        "color": "#1f78b4",
        "halo": {
          "color": "#ffffff",
          "width": 0.3
        }
      }
    },
    "provincial_park": {
      "type": "polygon",
      "source_layer": "whse_tantalis.ta_park_ecores_pa_svw",
      "fill": {
        "color": "#639b5f",
        "opacity": 0.161
      },
      "stroke": {
        "color": "#33a02c",
        "width": 0.66
      },
      "label": {
        "font": "Courier",
        "size": 8,
        "color": "#639b5f"
      }
    },
    "railway": {
      "type": "line",
      "source_layer": "whse_basemapping.gba_railway_tracks_sp",
      "stroke": {
        "color": "#000000",
        "width": 0.4
      },
      "note": "3 symbol layers — overlay/casing may apply"
    },
    "roads_dra": {
      "type": "line",
      "source_layer": "whse_basemapping.transport_line",
      "classification": {
        "field": "transport_line_type_code",
        "classes": {
          "RF": {
            "color": "#ffc485",
            "width": 1.3182,
            "label": "Freeway",
            "casing_color": "#9c9c9c",
            "casing_width": 1.86
          },
          "__empty__": {
            "color": "#484848",
            "width": 0.46,
            "opacity": 0.6
          },
          "RLO": {
            "color": "#484848",
            "width": 0.46,
            "label": "Local"
          },
          "TD": {
            "color": "#484848",
            "width": 0.46,
            "opacity": 0.6,
            "label": "Trail"
          }
        }
      },
      "label": {
        "font": "Arial",
        "size": 6,
        "color": "#4a4a4a"
      }
    },
    "stream_labels": {
      "type": "line",
      "source_layer": "whse_basemapping.fwa_named_streams",
      "stroke": {
        "color": "#fafafa",
        "width": 0,
        "dash": "no"
      },
      "label": {
        "font": "Helvetica",
        "size": 11,
        "style": "italic",
        "color": "#1f78b4",
        "halo": {
          "color": "#ffffff",
          "width": 0.3
        }
      }
    },
    "streams_all": {
      "type": "line",
      "source_layer": "bcfishpass.streams_vw",
      "classification": {
        "field": "feature_code",
        "classes": {
          "__empty__": {
            "color": "#a9e0ff",
            "width": 0.26,
            "opacity": 0.65
          },
          "GA24850150": {
            "color": "#a9e0ff",
            "width": 0.3,
            "label": "Stream - intermittent"
          }
        }
      }
    }
  }
}
